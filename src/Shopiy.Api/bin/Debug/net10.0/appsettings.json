{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=OrderManagementDb;Username=postgres;Password=your_password",
    "ReadReplica": "Host=localhost;Port=5432;Database=OrderManagementReplica;Username=postgres;Password=your_password",
  },

  "Jwt": {
    "Issuer": "OrderManagement.API",
    "Audience": "OrderManagement.Client",
    "Secret": "YOUR_SUPER_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
